void FuncionMotorHombro(realMotor& motor){ //Funcion para controlar al servo                                  DEL HOMBRO

    motor.valorPotenciometro = analogRead(motor.pinPotenciometro);
    // Lee el valor actual del potenciómetro y conviértelo a grados
    motor.anguloReal = map(motor.valorPotenciometro, motor.minvalpot, motor.maxvalpot, motor.minangpot, motor.maxangpot); // asignacion de angulos corrigiendo los problemas del sensor
    
    // Calcula el error
    motor.error = motor.anguloDeseado - motor.anguloReal;
    // Calcula la señal de control del primer lazo (cerrado)
    motor.output = motor.Kp * motor.error;

    //Añadimos el componente del lazo de realimentación gravitatorio a la salida del sistema
    double gan_gravit = calcularCompensacionGravedad(motor.anguloReal);
    double salidaReal= motor.output + gan_gravit;

    // Toma el valor absoluto del output para PWM
    int absSalidaReal = abs(int(salidaReal));
    // Limita el valor a un máximo de 255 para la señal PWM
    absSalidaReal = constrain(absSalidaReal, 0, 255);
    
    // Actualiza el valor de salida cada x miliseconds      ->  EN EL OBJETO  <-
    static unsigned long tiempoactualizacion = 0;
    if (millis() - tiempoactualizacion >= 30) {
         motor.salidaFinal=salidaReal;
         motor.absSalidaFinal=absSalidaReal;
        tiempoactualizacion = millis();
    }



      //APLICO EL OUTPUT AL PUENTE H
      motor.manageMotor();
      actualizarRealimentacion();
}




void FuncionMotorBase(realMotor& motor){ //Funcion para controlar al servo                                          DE LA BASE

    motor.valorPotenciometro = analogRead(motor.pinPotenciometro);
    // Lee el valor actual del potenciómetro y conviértelo a grados
    motor.anguloReal = map(motor.valorPotenciometro, motor.minvalpot, motor.maxvalpot, motor.minangpot, motor.maxangpot); // asignacion de angulos corrigiendo los problemas del sensor
    
    // Calcula el error
    motor.error = motor.anguloDeseado - motor.anguloReal;
    // Calcula la señal de control del primer lazo (cerrado)
    motor.P = motor.Kp * motor.error;

    // Computar PID como normal
        unsigned long now = millis();
        double timeChange = (double)(now - motor.lastTime);
      
        if (timeChange >= 50) {  // Intervalo de cálculo, ajusta según necesites
            // Calcular el término integral
            motor.I += (motor.Ki * motor.error);
            motor.I = constrain(motor.I, 0, 255);  // Evita el wind-up del integrador
            
            // Calcular el término derivativo
            motor.D = (motor.anguloReal - motor.lastInput);
    
            // Calcular salida PID
            motor.output = motor.P  - motor.Kd * motor.D; //+motor.I;
            
    
            // Recordar algunos valores para la próxima vez
            motor.lastInput = motor.anguloReal;
            motor.lastTime = now;
        }
    
    motor.salidaFinal = motor.output;
    
    // Actualiza el valor de salida                             ->  EN EL OBJETO  <-
    // Toma el valor absoluto del output para PWM
    motor.absSalidaFinal = abs(int(motor.salidaFinal));
    
    //Con esta linea estoy mandando un pulso proporcional al error real
      motor.absSalidaFinal = map(motor.absSalidaFinal, 0, 100, 0, 200);
      
    // Limita el valor a un máximo de 255 para la señal PWM
    motor.absSalidaFinal = constrain(motor.absSalidaFinal, 0, 255);

      //APLICO EL OUTPUT AL PUENTE H
      motor.manageMotor();
      actualizarRealimentacion();
}







                                      //  Función para calcular la compensación de torque por gravedad
double calcularCompensacionGravedad(double angulo) {
    // Convertir grados a radianes
    double radianes = angulo * (PI / 180.0);
    double componentegravedad = gravComp_1 * cos(radianes); //calculo el torque con el componente del peso dado el angulo
    int correcciongravedad = (int)(componentegravedad * (255 / 1.47));
    
    // Limitar el valor a rango PWM (-255 a 255)
    correcciongravedad = constrain(correcciongravedad, -255, 255);
    
    return correcciongravedad;
}

