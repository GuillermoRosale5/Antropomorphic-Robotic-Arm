                      // Parámetros del Hardware
    int pinPotenciometro;  // Pin para el potenciómetro
    int entradaA;          // Primer pin de control para el puente H
    int entradaB;          // Segundo pin de control para el puente H
    int enable;           // Pin de habilitación para el puente H
    int minvalpot = 0;     // Valor minimo de lectura del potenciometro
    int maxvalpot = 1023;  // Valor máximo de lectura del potenciometro
    int minangpot = 0;
    int maxangpot = 180;
    
                      //Parámetros del control
    int valorPotenciometro;      
    int anguloReal;
    int anguloDeseado;
    int salidaFinal = 0;
    int absSalidaFinal = 0;
 
//                        ORDEN CONSTRUCTOR: entradaA, entradaB, enable, pinPotenciometro, Kp, Ki, Kd, minvalpot, maxvalpot, minangpot, maxangpot
    
    // Constructor para inicializar todos los pines necesarios
    realMotor(int _entradaA, int _entradaB, int _enable, int _pinPotenciometro, double _Kp, double _Ki, double _Kd, int _minvalpot, int _maxvalpot, int _minangpot, int _maxangpot)
    : entradaA(_entradaA), entradaB(_entradaB), enable(_enable), pinPotenciometro(_pinPotenciometro),
      Kp(_Kp), Ki(_Ki), Kd(_Kd), minvalpot(_minvalpot), maxvalpot(_maxvalpot), minangpot(_minangpot), maxangpot(_maxangpot) {
        pinMode(pinPotenciometro, INPUT);  // Configura el pin del potenciómetro como entrada
        pinMode(entradaA, OUTPUT);         // Configura el primer pin de control como salida
        pinMode(entradaB, OUTPUT);         // Configura el segundo pin de control como salida
        pinMode(enable, OUTPUT);           // Configura el pin de habilitación como salida
    }

      void FuncionMotorBase(realMotor& motor){};
      void FuncionMotorHombro(realMotor& motor){};

    //   Función para manejar el control del motor mediante el puente H
    void manageMotor() {                                                            // A tener actualizado antes salidaFinal y absSalidaFinal
      
        // Control del motor mediante el puente H
        if (salidaFinal > 0) {
            digitalWrite(entradaA, HIGH);
            digitalWrite(entradaB, LOW);
        } else if (salidaFinal < 0) {
            digitalWrite(entradaA, LOW);
            digitalWrite(entradaB, HIGH);
        } else {
            digitalWrite(entradaA, LOW);
            digitalWrite(entradaB, LOW);
        }

        // Aplicar el ciclo de trabajo correcto
        analogWrite(enable, absSalidaFinal);                                   //ejecutador
    }
};
